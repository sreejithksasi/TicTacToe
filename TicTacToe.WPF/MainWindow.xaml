<Window x:Class="TicTacToe.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tic-Tac-Toe" Height="650" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300"
                    Visibility="{Binding IsSetupVisible, Converter={StaticResource BoolToVis}, FallbackValue=Visible}">

            <TextBlock Text="Tic-Tac-Toe Setup" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" TextAlignment="Center" Foreground="#333"/>

            <TextBlock Text="Player X (Goes First):" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox SelectedValue="{Binding PlayerXType}" SelectedValuePath="Content" Margin="0,0,0,15" FontSize="14" Padding="5">
                <ComboBoxItem Content="Human" IsSelected="True"/>
                <ComboBoxItem Content="EasyAI"/>
                <ComboBoxItem Content="MediumAI"/>
            </ComboBox>

            <TextBlock Text="Player O:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox SelectedValue="{Binding PlayerOType}" SelectedValuePath="Content" Margin="0,0,0,15" FontSize="14" Padding="5">
                <ComboBoxItem Content="Human" IsSelected="True"/>
                <ComboBoxItem Content="EasyAI"/>
                <ComboBoxItem Content="MediumAI"/>
            </ComboBox>

            <TextBlock Text="Board Size (3 - 10):" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding BoardSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30" FontSize="16" Padding="5" TextAlignment="Center"/>

            <Button Content="Start Game" Command="{Binding StartGameCommand}" Height="45" FontSize="18" FontWeight="Bold" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <Grid Visibility="{Binding IsGameVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding GameStatusText, FallbackValue='Player X Turn'}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding BoardCells}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding BoardSize}" Columns="{Binding BoardSize}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Symbol}" 
                                Command="{Binding ClickCommand}" 
                                Foreground="{Binding TextColor}"
                                FontSize="42" FontWeight="Heavy" 
                                Width="60" Height="60" Margin="2"
                                Background="White" BorderBrush="DarkGray" BorderThickness="1" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWinningCell}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.2" Duration="0:0:0.4" 
                                                                         AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0"
                        Visibility="{Binding IsGameOver, Converter={StaticResource BoolToVis}}">
                <Button Content="Continue" Command="{Binding ContinueCommand}" Height="45" Width="150" FontSize="16" FontWeight="Bold" Background="#28A745" Foreground="White" BorderThickness="0" Margin="0,0,20,0" Cursor="Hand"/>
                <Button Content="Main Menu" Command="{Binding ReturnToMenuCommand}" Height="45" Width="150" FontSize="16" FontWeight="Bold" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>